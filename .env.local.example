# Copie este arquivo para .env.local e preencha com suas credenciais
# No Netlify: Site settings → Environment variables → Add variable

# EmailJS — https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# URL do seu site (usada nas meta tags de SEO / Open Graph)
NEXT_PUBLIC_SITE_URL=https://seusite.netlify.app
